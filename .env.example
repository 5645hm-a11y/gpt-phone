# =============================================
#  GPT Phone Line - הגדרות
# =============================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- כתובת שרת ציבורית (ngrok / render / Railway) ---
# חובה כדי ש-Twilio יוכל לנגן את קבצי האודיו
# לדוגמה: https://abc123.ngrok-free.app
BASE_URL=https://your-public-url.ngrok-free.app

# --- הגדרות אופציונליות ---

# מודל GPT (ברירת מחדל: gpt-4o-mini – זול ומהיר)
GPT_MODEL=gpt-4o-mini

# קול TTS של OpenAI: alloy | echo | fable | onyx | nova | shimmer
# nova נשמעת הכי טבעית לעברית
TTS_VOICE=nova

# שפת זיהוי דיבור (Twilio STT)
TTS_LANGUAGE=he-IL

# ברכה ראשונית לשיחה
GREETING_TEXT=שלום! אני עוזר AI. שאל אותי כל שאלה.

# פרומפט מערכת מותאם אישית (אופציונלי)
# SYSTEM_PROMPT=אתה עוזר טכני של חברת XYZ...

# פורט השרת (ברירת מחדל: 5000)
PORT=5000

# DEBUG mode (true/false)
FLASK_DEBUG=false
